# Database connection string for PostgreSQL
# Format: postgresql://username:password@host:port/database

# Development database (remote)
DATABASE_URL=postgresql://user:password@localhost:5432/emma_foundation_dev

# Production database (set in Vercel/hosting dashboard)
# DATABASE_URL=postgresql://user:password@production-host:5432/emma_foundation

# Environment
NODE_ENV=development

# Admin API Key (minimum 32 characters)
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Never commit the actual key to git
ADMIN_API_KEY=your-secure-admin-api-key-min-32-chars
